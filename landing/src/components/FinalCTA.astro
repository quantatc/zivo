---
const APP_URL = "https://app.tafarax.com";
---

<section class="section">
  <div class="container-page relative z-10">
    <div class="relative glass-strong p-10 md:p-16 overflow-hidden reveal">
      <div class="glow-indigo w-[500px] h-[500px] -top-40 left-1/2 -translate-x-1/2 opacity-60"></div>
      <div class="glow-cyan w-[400px] h-[400px] bottom-0 right-0 opacity-40"></div>

      <div class="relative max-w-3xl mx-auto text-center">
        <h2 class="text-[clamp(2rem,5vw,4rem)] font-black leading-[1.05] tracking-tight mb-5">
          Ready to give your ops team <br class="hidden md:block" />
          an <span class="gradient-text animate-gradient">AI advantage?</span>
        </h2>
        <p class="text-lg md:text-xl text-[var(--color-subtle)] mb-10 max-w-2xl mx-auto">
          Deploy in an afternoon. Results from day one. No SaaS lock-in — ever.
        </p>
        <div class="flex flex-wrap justify-center items-center gap-3">
          <a href={`${APP_URL}/signup`} class="btn btn-primary text-base px-6 py-3.5">
            Start free trial
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="mailto:hello@tafarax.com" class="btn btn-ghost text-base px-6 py-3.5">
            Talk to us
          </a>
        </div>

        <div class="mt-10 flex flex-wrap justify-center items-center gap-6 text-xs text-[var(--color-muted)]">
          <div class="flex items-center gap-1.5">
            <div class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse-slow"></div>
            Demo environment live now
          </div>
          <div class="font-mono">zivo.tafarax.com</div>
        </div>
      </div>
    </div>
  </div>
</section>
