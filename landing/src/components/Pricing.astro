---
const managedTiers = [
  { name: "Starter", users: "Up to 10 users", price: "$399" },
  { name: "Growth", users: "Up to 25 users", price: "$799" },
  { name: "Scale", users: "Up to 50 users", price: "$1,499" },
];

const managedFeatures = [
  "All three pillars: chat, workflows, dashboards",
  "Custom subdomain + email & Slack support",
  "Per-tenant Postgres on shared infrastructure",
  "SSO (Google, Microsoft) on Scale tier",
  "Workflow build credit packs from $1,000",
];

const enterpriseLines = [
  { label: "Platform fee", value: "from $3,000/mo" },
  { label: "Setup fee (one-time)", value: "from $5,000" },
  { label: "Workflow / agent build", value: "$200/hr" },
  { label: "Annual prepay discount", value: "10–15%", accent: true },
];

const enterpriseFeatures = [
  "Dedicated VM per tenant — no shared kernel",
  "SAML SSO + RBAC + audit log export to SIEM",
  "99.9% uptime SLA + dedicated success manager",
  "Bring your own LLM provider keys",
  "Quarterly business review with founder",
];
---

<section id="pricing" class="section">
  <div class="glow-indigo w-[600px] h-[600px] -top-20 left-1/4 opacity-25"></div>
  <div class="glow-cyan w-[400px] h-[400px] bottom-20 right-0 opacity-20"></div>

  <div class="container-page relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-14 reveal">
      <span class="eyebrow mb-5">Deployment &amp; Pricing</span>
      <h2 class="text-[clamp(1.8rem,4vw,3rem)] font-black leading-tight mb-4">
        Two paths. <span class="gradient-text">Same product underneath.</span>
      </h2>
      <p class="text-lg text-[var(--color-subtle)]">
        <span class="text-[var(--color-text)] font-semibold">Managed</span> is for teams that want Zivo running tomorrow with minimal IT involvement.
        <span class="text-[var(--color-text)] font-semibold">Enterprise</span> is for teams that need a dedicated tenant, SSO, audit-log export, and a contract their procurement team can sign.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 max-w-5xl mx-auto items-stretch">
      <div class="reveal">
        <div class="glass p-8 md:p-10 h-full flex flex-col relative overflow-hidden ring-1 ring-cyan-400/30">
          <div class="absolute -top-20 -right-20 w-48 h-48 rounded-full bg-cyan-500/15 blur-3xl pointer-events-none"></div>

          <div class="relative mb-6">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-xl font-bold">Managed</h3>
              <span class="chip !text-cyan-300 border-cyan-400/30 bg-cyan-500/10">From $399/mo</span>
            </div>
            <p class="text-sm text-[var(--color-muted)]">
              Hosted by Zivo. Per-tenant compose stack on shared infrastructure with your own Postgres database, your own subdomain, and your own admin. Built for SMBs and growing operations teams.
            </p>
          </div>

          <div class="relative mb-6 rounded-xl border border-[var(--color-border)] overflow-hidden">
            <div class="grid grid-cols-[1fr_auto_auto] text-[10px] uppercase tracking-widest text-[var(--color-muted)] font-mono px-4 py-2 bg-white/[0.02] border-b border-[var(--color-border)]">
              <span>Tier</span>
              <span class="text-right pr-6">Users</span>
              <span class="text-right">/mo</span>
            </div>
            {managedTiers.map((t) => (
              <div class="grid grid-cols-[1fr_auto_auto] items-center px-4 py-3 text-sm border-b border-[var(--color-border)] last:border-b-0">
                <span class="font-semibold">{t.name}</span>
                <span class="text-right pr-6 text-[var(--color-subtle)]">{t.users}</span>
                <span class="text-right font-bold text-cyan-300">{t.price}</span>
              </div>
            ))}
          </div>

          <a href="mailto:hello@zivoworkspace.ai?subject=Zivo%20Managed%20Pilot" class="relative btn btn-ghost w-full mb-2">
            Start a Managed pilot
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <p class="relative text-center text-[11px] text-[var(--color-muted)] mb-6">
            Up and running within two weeks.
          </p>

          <div class="relative space-y-2.5 flex-1">
            {managedFeatures.map((f) => (
              <div class="flex items-start gap-2.5 text-sm">
                <div class="h-4 w-4 rounded-full bg-cyan-500/15 border border-cyan-400/30 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-[var(--color-text)]">{f}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="reveal" style="transition-delay: 120ms">
        <div class="glass-strong ring-1 ring-indigo-500/40 p-8 md:p-10 h-full flex flex-col relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-56 h-56 rounded-full bg-indigo-500/25 blur-3xl pointer-events-none"></div>
          <div class="absolute -bottom-20 -left-20 w-56 h-56 rounded-full bg-violet-500/20 blur-3xl pointer-events-none"></div>

          <div class="relative mb-6">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-xl font-bold">Enterprise</h3>
              <span class="chip !text-indigo-200 border-indigo-400/30 bg-indigo-500/15">From $3,000/mo</span>
            </div>
            <p class="text-sm text-[var(--color-muted)] max-w-md">
              A fully isolated tenant on dedicated infrastructure (Hetzner today, Azure or your own cloud on request). Your security review, your audit log, your success manager.
            </p>
          </div>

          <div class="relative mb-6 rounded-xl border border-[var(--color-border)] overflow-hidden">
            <div class="grid grid-cols-[1.2fr_auto] text-[10px] uppercase tracking-widest text-[var(--color-muted)] font-mono px-4 py-2 bg-white/[0.02] border-b border-[var(--color-border)]">
              <span>Component</span>
              <span class="text-right">Investment</span>
            </div>
            {enterpriseLines.map((line) => (
              <div class="grid grid-cols-[1.2fr_auto] items-center px-4 py-3 text-sm border-b border-[var(--color-border)] last:border-b-0">
                <span class="font-semibold">{line.label}</span>
                <span class={`text-right font-bold ${line.accent ? "text-emerald-300" : "text-indigo-200"}`}>{line.value}</span>
              </div>
            ))}
          </div>

          <a href="mailto:hello@zivoworkspace.ai?subject=Zivo%20Enterprise%20Demo" class="relative btn btn-primary w-full mb-2">
            Book an Enterprise demo
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <p class="relative text-center text-[11px] text-[var(--color-muted)] mb-6">
            30-day paid pilot. 15% discount if you convert to annual.
          </p>

          <div class="relative space-y-2.5 flex-1">
            {enterpriseFeatures.map((f) => (
              <div class="flex items-start gap-2.5 text-sm">
                <div class="h-4 w-4 rounded-full bg-indigo-500/20 border border-indigo-400/30 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-[var(--color-text)]">{f}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="reveal mt-10 max-w-4xl mx-auto">
      <div class="glass p-5 flex flex-col md:flex-row items-start md:items-center gap-4">
        <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-indigo-500/20 to-violet-500/10 border border-indigo-400/20 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <div class="flex-1">
          <div class="text-sm font-semibold mb-1">LLM usage is pass-through.</div>
          <p class="text-sm text-[var(--color-subtle)] leading-relaxed">
            Zivo connects to your AI providers of choice — OpenAI, Anthropic, Google Gemini, Azure OpenAI, or your own self-hosted models. You bring the API key, you pay the provider directly. No markup, no per-token fees from us, total cost transparency.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
