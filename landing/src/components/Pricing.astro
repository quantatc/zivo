---
const APP_URL = "https://app.tafarax.com";

const enterpriseFeatures = [
  "Unlimited users across your entire company",
  "All AI agents, workflows, and analytics",
  "Private deployment on your infrastructure",
  "SSO, SAML, and role-based access control",
  "Bring your own LLM provider keys",
  "Guided setup and white-glove onboarding",
  "Priority email support, 24h response SLA",
  "Custom agent and workflow development",
  "Dedicated customer success contact",
  "Quarterly business reviews",
];

const managedFeatures = [
  "Everything in Enterprise",
  "Fully managed, fully hosted by Zivo",
  "Complete white-label branding",
  "Your own custom domain",
  "Multi-tenant architecture",
  "Reseller and revenue-share options",
  "Built for agencies and consultancies",
];
---

<section id="pricing" class="section">
  <div class="glow-indigo w-[600px] h-[600px] -top-20 left-1/4 opacity-25"></div>
  <div class="glow-cyan w-[400px] h-[400px] bottom-20 right-0 opacity-20"></div>

  <div class="container-page relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-14 reveal">
      <span class="eyebrow mb-5">Pricing</span>
      <h2 class="text-[clamp(1.8rem,4vw,3rem)] font-black leading-tight mb-4">
        One plan. <span class="gradient-text">Everything your enterprise needs.</span>
      </h2>
      <p class="text-lg text-[var(--color-subtle)]">
        Simple, transparent, and built for scale. No per-seat traps. No payment processing on our side.
      </p>
    </div>

    <div class="grid md:grid-cols-[1.15fr_1fr] gap-5 max-w-5xl mx-auto items-stretch">
      <div class="reveal">
        <div class="glass-strong ring-1 ring-indigo-500/40 p-8 md:p-10 h-full flex flex-col relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-56 h-56 rounded-full bg-indigo-500/25 blur-3xl pointer-events-none"></div>
          <div class="absolute -bottom-20 -left-20 w-56 h-56 rounded-full bg-violet-500/20 blur-3xl pointer-events-none"></div>

          <div class="relative flex items-start justify-between mb-6">
            <div>
              <div class="flex items-center gap-2 mb-2">
                <h3 class="text-xl font-bold">Enterprise</h3>
                <span class="chip !text-emerald-300 border-emerald-500/30 bg-emerald-500/10">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse-slow"></span>
                  Available now
                </span>
              </div>
              <p class="text-sm text-[var(--color-muted)] max-w-md">
                Deploy Zivo on your infrastructure with full support. Your data, your control, your brand.
              </p>
            </div>
          </div>

          <div class="relative mb-6">
            <div class="flex items-baseline gap-2 mb-1.5">
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-muted)] font-mono">Starting at</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl md:text-6xl font-black">$299</span>
              <div class="flex flex-col leading-tight">
                <span class="text-sm text-[var(--color-subtle)]">per month</span>
                <span class="text-xs text-[var(--color-muted)]">billed annually</span>
              </div>
            </div>
          </div>

          <a href="mailto:hello@tafarax.com?subject=Zivo%20Enterprise%20Demo" class="relative btn btn-primary w-full mb-2">
            Book a demo
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <p class="relative text-center text-[11px] text-[var(--color-muted)] mb-6">
            Talk to our team. Get pricing tailored to your scale.
          </p>

          <div class="relative grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2.5 flex-1">
            {enterpriseFeatures.map((f) => (
              <div class="flex items-start gap-2.5 text-sm">
                <div class="h-4 w-4 rounded-full bg-indigo-500/20 border border-indigo-400/30 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-[var(--color-text)]">{f}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="reveal" style="transition-delay: 120ms">
        <div class="glass p-8 md:p-10 h-full flex flex-col relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-48 h-48 rounded-full bg-cyan-500/10 blur-3xl pointer-events-none"></div>

          <div class="relative flex items-start justify-between mb-6">
            <div>
              <div class="flex items-center gap-2 mb-2">
                <h3 class="text-xl font-bold">Managed</h3>
                <span class="chip !text-cyan-300 border-cyan-400/30 bg-cyan-500/10">
                  Coming soon
                </span>
              </div>
              <p class="text-sm text-[var(--color-muted)]">
                We host, we manage, you white-label. Built for agencies, consultancies, and resellers.
              </p>
            </div>
          </div>

          <div class="relative mb-6">
            <div class="flex items-baseline gap-2 mb-1.5">
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-muted)] font-mono">Pricing</span>
            </div>
            <div class="text-3xl md:text-4xl font-black text-[var(--color-subtle)]">
              Revenue share
            </div>
            <div class="text-xs text-[var(--color-muted)] mt-1">Details released at launch</div>
          </div>

          <a href="mailto:hello@tafarax.com?subject=Zivo%20Managed%20Waitlist" class="relative btn btn-ghost w-full mb-2">
            Join the waitlist
          </a>
          <p class="relative text-center text-[11px] text-[var(--color-muted)] mb-6">
            Early partners get preferred pricing at launch.
          </p>

          <div class="relative space-y-2.5 flex-1">
            {managedFeatures.map((f) => (
              <div class="flex items-start gap-2.5 text-sm">
                <div class="h-4 w-4 rounded-full bg-cyan-500/15 border border-cyan-400/30 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-[var(--color-text)]">{f}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="reveal mt-10 max-w-4xl mx-auto">
      <div class="glass p-5 flex flex-col md:flex-row items-start md:items-center gap-4">
        <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-indigo-500/20 to-violet-500/10 border border-indigo-400/20 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <div class="flex-1">
          <div class="text-sm font-semibold mb-1">LLM usage is pass-through.</div>
          <p class="text-sm text-[var(--color-subtle)] leading-relaxed">
            Zivo connects to the AI providers of your choice. You bring your own API keys and pay the provider directly for model usage. No markups, no per-token fees from us, total transparency.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
