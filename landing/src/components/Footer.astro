---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-[var(--color-border)] py-12 mt-10">
  <div class="container-page">
    <div class="grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-8 mb-10">
      <div>
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img src="/logo.png" alt="Zivo" class="h-7 w-7 rounded-md" />
          <span class="text-lg font-bold tracking-tight gradient-text">Zivo</span>
        </a>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-xs mb-5">
          The enterprise AI workspace for ops teams that want to move fast — without giving up control.
        </p>
        <div class="flex items-center gap-2">
          <a href="https://github.com/quantatc/zivo" aria-label="GitHub" class="h-9 w-9 rounded-lg border border-[var(--color-border-strong)] flex items-center justify-center hover:bg-white/5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.58v-2.02c-3.34.72-4.04-1.6-4.04-1.6-.54-1.38-1.33-1.75-1.33-1.75-1.1-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.8 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.92 0-1.3.47-2.38 1.24-3.22-.13-.3-.54-1.52.1-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.87.12 3.17.77.84 1.24 1.92 1.24 3.22 0 4.6-2.8 5.6-5.48 5.9.43.37.8 1.1.8 2.22v3.3c0 .32.22.7.83.58C20.56 22.3 24 17.8 24 12.5 24 5.87 18.63.5 12 .5z"/></svg>
          </a>
          <a href="https://x.com/" aria-label="X / Twitter" class="h-9 w-9 rounded-lg border border-[var(--color-border-strong)] flex items-center justify-center hover:bg-white/5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.linkedin.com/" aria-label="LinkedIn" class="h-9 w-9 rounded-lg border border-[var(--color-border-strong)] flex items-center justify-center hover:bg-white/5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.67H9.32V9h3.41v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.6 0 4.27 2.37 4.27 5.46v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-muted)] font-mono mb-4">Product</div>
        <ul class="space-y-2.5 text-sm">
          <li><a href="#features" class="text-[var(--color-subtle)] hover:text-white transition-colors">Features</a></li>
          <li><a href="#how" class="text-[var(--color-subtle)] hover:text-white transition-colors">How it works</a></li>
          <li><a href="#use-cases" class="text-[var(--color-subtle)] hover:text-white transition-colors">Use cases</a></li>
          <li><a href="#pricing" class="text-[var(--color-subtle)] hover:text-white transition-colors">Pricing</a></li>
        </ul>
      </div>

      <div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-muted)] font-mono mb-4">Resources</div>
        <ul class="space-y-2.5 text-sm">
          <li><a href="https://github.com/quantatc/zivo" class="text-[var(--color-subtle)] hover:text-white transition-colors">GitHub</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">Documentation</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">Changelog</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">Status</a></li>
        </ul>
      </div>

      <div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-muted)] font-mono mb-4">Company</div>
        <ul class="space-y-2.5 text-sm">
          <li><a href="mailto:hello@tafarax.com" class="text-[var(--color-subtle)] hover:text-white transition-colors">Contact</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">About</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">Privacy</a></li>
          <li><a href="#" class="text-[var(--color-subtle)] hover:text-white transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-[var(--color-muted)]">
      <div>© {year} Zivo · Built on open source</div>
      <div class="font-mono">zivo.tafarax.com</div>
    </div>
  </div>
</footer>
