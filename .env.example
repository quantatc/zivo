WEBUI_NAME=Zivo Workspace
WEBUI_SECRET_KEY=replace-with-a-long-random-secret
WEBUI_URL=https://zivo.tafarax.com
ENABLE_SIGNUP=false

POSTGRES_DB=zivo
POSTGRES_USER=zivo
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

LITELLM_MASTER_KEY=replace-with-a-litellm-master-key
LITELLM_SALT_KEY=replace-with-a-long-random-salt
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=replace-with-a-strong-admin-password

OPENROUTER_API_KEY=

CHROMA_AUTH_TOKEN=replace-with-a-long-random-chroma-token
N8N_ENCRYPTION_KEY=replace-with-a-long-random-n8n-encryption-key
WEBHOOK_URL=https://zivo.tafarax.com/n8n/
REDIS_PASSWORD=

# --- Atlas Operations demo --------------------------------------------------
# Where the daily ops digest workflow posts the markdown brief.
# For demos, point this at a https://webhook.site URL; for prod, a Slack/Teams webhook.
OPS_DIGEST_WEBHOOK_URL=
# Override the LiteLLM model used by atlas-api for email drafting.
# Defaults to "Zivo Fast (GPT-5 Mini)" — must match a model alias in litellm/config.yaml.
ATLAS_EMAIL_MODEL=

# Optional later expansion if you move beyond the demo setup:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# VERTEXAI_PROJECT=
# VERTEXAI_LOCATION=us-central1
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
